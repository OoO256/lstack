{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["goal", "requirements", "tasks"],
  "properties": {
    "goal": {
      "type": "string",
      "description": "사용자 의도 한 줄 요약"
    },
    "design": {
      "type": "string",
      "description": "architect 분석 결과 파일 경로 (예: .lstack/design.md)"
    },
    "requirements": {
      "type": "array",
      "description": "사용자 요구사항 + 설계 결정사항. 모든 task는 이를 충족해야 한다.",
      "items": {
        "type": "object",
        "required": ["id", "type", "content", "status", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string", "pattern": "^R[0-9]+$" },
          "type": {
            "type": "string",
            "enum": ["requirement", "design_decision"],
            "description": "requirement: 사용자 요구사항, design_decision: Phase 2에서 결정한 설계 사항"
          },
          "content": { "type": "string", "description": "요구사항 또는 설계 결정 내용" },
          "rationale": { "type": "string", "description": "design_decision인 경우 결정 근거" },
          "status": { "type": "string", "enum": ["pending", "pass", "fail"] },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "check", "verify_agent", "status"],
              "properties": {
                "id": { "type": "string", "pattern": "^AC[0-9]+$" },
                "check": { "type": "string", "description": "구체적 검증 항목" },
                "verify_agent": { "type": "string", "description": "검증할 외부 agent" },
                "status": { "type": "string", "enum": ["pending", "pass", "fail"] }
              }
            }
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "action", "status", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string", "pattern": "^T[0-9]+$" },
          "action": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pending", "in_progress", "done", "verified", "failed"]
          },
          "agent": {
            "type": "string",
            "description": "실행할 agent (예: general-purpose, superpowers:code-reviewer, oh-my-claudecode:executor)"
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string", "pattern": "^T[0-9]+$" }
          },
          "acceptance_criteria": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "check", "verify_agent", "status"],
              "properties": {
                "id": { "type": "string", "pattern": "^AC[0-9]+$" },
                "check": {
                  "type": "string",
                  "description": "구체적 검증 항목 — context 없는 다른 agent가 봐도 동일하게 판단 가능해야 함"
                },
                "verify_agent": {
                  "type": "string",
                  "description": "검증할 외부 agent (예: superpowers:code-reviewer). 필수."
                },
                "status": {
                  "type": "string",
                  "enum": ["pending", "pass", "fail"]
                }
              }
            }
          },
          "worklog": {
            "type": "object",
            "description": "task 완료 후 agent가 기록하는 작업 로그",
            "properties": {
              "summary": { "type": "string", "description": "작업 요약" },
              "decisions": {
                "type": "array",
                "items": { "type": "string" },
                "description": "구현 중 내린 의사결정"
              },
              "insights": {
                "type": "array",
                "items": { "type": "string" },
                "description": "구현 중 발생한 암묵지 — 코드에 드러나지 않는 발견, 주의점, 노하우"
              },
              "changes": {
                "type": "array",
                "items": { "type": "string" },
                "description": "동작 변경사항 — 기존 동작이 어떻게 바뀌었는지"
              }
            }
          }
        }
      }
    }
  }
}
